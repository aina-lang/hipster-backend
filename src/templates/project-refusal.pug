extends layout

block content
  h2 Bonjour #{clientName},
  p Nous avons examiné votre demande de projet et nous vous informons qu'elle n'a malheureusement pas pu être acceptée.

  .card
    h3.card-title Détails du projet

    table(width="100%" cellpadding="0" cellspacing="0" border="0")
      tr
        td.row-label Nom du projet
        td.row-value #{projectName}

      if reason
        tr
          td(colspan="2" style="padding: 18px 0 0 0;")
            span.eyebrow Motif du refus
        tr
          td(colspan="2")
            .info-box.info-box-danger
              p #{reason}

  p(style="margin-top: 32px;") Nous vous encourageons à nous contacter si vous avez des questions ou si vous souhaitez soumettre une nouvelle demande avec des modifications.

  div(style="text-align: center; margin-top: 40px;")
    a.btn(href=projectUrl) Voir les détails
