extends layout

block content
  h2 Bonjour #{clientName},
  p Nous avons bien reçu votre ticket support "#{ticketTitle}", mais nous ne pouvons malheureusement pas l'accepter pour le moment.

  .card
    h3.card-title Informations

    table(width="100%" cellpadding="0" cellspacing="0" border="0")
      tr
        td.row-label Sujet
        td.row-value #{ticketTitle}

      tr
        td.row-label.row-sep État
        td.row-value.row-sep
          span.badge.badge-danger Refusé

      if reason
        tr
          td.row-label.row-sep Motif du refus
          td.row-value.row-sep #{reason}

  p(style="margin-top: 32px;") Si vous pensez qu'il s'agit d'une erreur ou si vous avez besoin de plus de précisions, n'hésitez pas à nous recontacter.

  div(style="text-align: center; margin-top: 40px;")
    a.btn(href=appUrl) Retourner sur l'application
