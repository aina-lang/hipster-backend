extends layout

block content
  h2 Bonjour #{memberName},
  p Vous avez été assigné(e) au projet <strong>#{projectName}</strong>.

  if role
    p(style="color: #6E4A35; font-size: 15px;") Votre rôle dans ce projet : <strong style="color: #3A2A1E;">#{role}</strong>

  .card
    h3.card-title Détails du projet

    table(width="100%" cellpadding="0" cellspacing="0" border="0")
      tr
        td.row-label Nom du projet
        td.row-value #{projectName}

      if role
        tr
          td.row-label.row-sep Votre rôle
          td.row-value.row-sep #{role}

      if projectDescription
        tr
          td(colspan="2" style="padding: 20px 0 0 0;")
            span.eyebrow Description du projet
        tr
          td(colspan="2" style="padding: 8px 0 0 0; font-size: 14px; color: #6E4A35; line-height: 1.6;") #{projectDescription}

      if startDate
        tr
          td.row-label.row-sep Date de début
          td.row-value.row-sep #{startDate}

      if endDate
        tr
          td.row-label.row-sep Date de fin prévue
          td.row-value.row-sep #{endDate}

  .info-box.info-box-brand
    p
      strong(style="color: #3A2A1E;") Prochaines étapes :
      br
      | Connectez-vous à votre espace collaborateur pour consulter les détails complets du projet, accéder aux fichiers partagés, et commencer à travailler avec votre équipe.

  div(style="text-align: center; margin-top: 40px;")
    a.btn(href=appUrl + '/app/projects') Accéder au projet

  p(style="margin-top: 40px; font-size: 13px; color: #8A7566; line-height: 1.6;") Si vous avez des questions concernant ce projet ou votre rôle, n'hésitez pas à contacter votre chef de projet ou l'équipe administrative.
