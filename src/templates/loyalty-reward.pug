extends layout

block content
  div(style="text-align: center; margin-bottom: 32px;")
    h2 Félicitations !
    p Vous avez atteint un nouveau palier de fidélité.

  .card(style="text-align: center;")
    h3(style="margin-top: 0; font-size: 20px; color: #3A2A1E;") Tier #{newTier}
    p(style="color: #6E4A35; font-size: 14px;") Vous avez progressé de <strong>#{oldTier}</strong> à <strong>#{newTier}</strong>.

    div(style="background-color: #ffffff; border: 1.5px dashed #C89B6E; padding: 20px; border-radius: 14px; margin-top: 24px;")
      span.eyebrow Votre nouvelle récompense
      p(style="margin: 8px 0 0 0; color: #3A2A1E; font-size: 18px; font-weight: 800;") #{reward}

  h3 Statistiques de votre compte
  ul(style="padding-left: 20px; margin: 0; font-size: 14px; color: #4A3B30;")
    li(style="margin-bottom: 8px;") Projets complétés : #{projectCount}
    li(style="margin-bottom: 8px;") Tier actuel : #{newTier}
    if nextTier
      li Prochain tier : <strong>#{nextTier}</strong> (#{projectsToNextTier} projets restants)
    else
      li(style="color: #8B5E3C; font-weight: 700;") Vous avez atteint le niveau maximum !

  p Merci de votre fidélité ! Nous sommes fiers de vous accompagner dans vos projets.

  div(style="text-align: center; margin-top: 40px;")
    a.btn(href=loyaltyUrl) Consulter mes avantages
