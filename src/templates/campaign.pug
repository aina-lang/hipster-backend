extends layout

block content
  h2 Bonjour #{userName},

  if description
    .info-box.info-box-brand
      p(style="font-style: italic;") #{description}

  div(style="white-space: pre-wrap; color: #3A2A1E; font-size: 16px; line-height: 1.8;")
    | #{content}

  div.divider

  p(style="font-size: 12px; color: #8A7566; text-align: center;")
    | Vous recevez cet email car vous faites partie de la communauté #{companyName}.
