extends layout

block content
  h2 Bonjour #{clientName},
  p Nous sommes ravis de vous informer que votre projet a été créé avec succès !

  .card
    h3.card-title Détails du projet

    table(width="100%" cellpadding="0" cellspacing="0" border="0")
      tr
        td.row-label Nom du projet
        td.row-value #{projectName}

      if startDate
        tr
          td.row-label.row-sep Date de début
          td.row-value.row-sep #{startDate}

      if endDate
        tr
          td.row-label.row-sep Échéance prévue
          td.row-value.row-sep #{endDate}

  p(style="margin-top: 32px;") Notre équipe se prépare à démarrer les travaux. Vous recevrez des mises à jour régulières sur l'avancement de votre projet.

  div(style="text-align: center; margin-top: 40px;")
    a.btn(href=projectUrl) Suivre mon projet
